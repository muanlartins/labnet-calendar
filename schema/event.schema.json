{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labnet-calendar/schemas/event.json",
  "title": "Event",
  "description": "One edition of an academic conference, workshop, symposium, journal, or themed special issue. Validation injects controlled vocabularies (areas, regions, societies, ranks) from data/tags.yaml at runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "series_id", "name", "edition", "type", "areas", "region", "last_verified"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Globally unique, kebab-case. Must equal the YAML filename stem."
    },
    "series_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "name": { "type": "string", "minLength": 1 },
    "full_name": { "type": "string" },
    "edition": { "type": "string", "minLength": 1 },
    "edition_number": { "type": "integer", "minimum": 1 },
    "type": { "type": "string", "enum": ["conference", "workshop", "symposium", "journal", "special_issue"] },
    "parent_id": { "type": ["string", "null"] },
    "society": { "type": ["string", "null"] },
    "areas": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "subareas": { "type": "array", "items": { "type": "string" } },
    "region": { "type": "string" },
    "tier": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "qualis": { "type": ["string", "null"] },
        "core": { "type": ["string", "null"] },
        "custom": { "type": ["string", "null"] }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "city": { "type": "string" },
        "country": { "type": "string" },
        "venue": { "type": "string" },
        "mode": { "type": "string" }
      }
    },
    "url": { "type": "string", "format": "uri" },
    "cfp_url": { "type": "string", "format": "uri" },
    "deadlines": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "date"],
        "properties": {
          "kind": { "type": "string" },
          "date": { "type": "string", "minLength": 10 },
          "timezone": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "event_dates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" }
      }
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "fetched_at": { "type": "string", "format": "date" }
        }
      }
    },
    "last_verified": { "type": "string", "format": "date" },
    "verified_by": { "type": "string" }
  }
}
